<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Class Timetable</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container-fluid p-4">
        <h1 class="mb-4 fw-bold">Class Timetable - 4-SEM</h1>
        
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Time</th>
                        <th class="text-center">Monday</th>
                        <th class="text-center">Tuesday</th>
                        <th class="text-center">Wednesday</th>
                        <th class="text-center">Thursday</th>
                        <th class="text-center">Friday</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold">9:10 - 10:10</td>
                        <td class="text-center">PE-I</td>
                        <td class="text-center">EAD LAB (B2)</td>
                        <td class="text-center">EIA</td>
                        <td class="text-center">PQT</td>
                        <td class="text-center">DHMS</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">10:15 - 11:15</td>
                        <td class="text-center">EEA<td>
                        <td class="text-center">PQT</td>
                        <td class="text-center">DHMS</td>
                        <td class="text-center">LIBRARY</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">11:15 - 12:15</td>
                        <td class="text-center">PQT</td>
                        <td class="text-center">PE-I</td>
                        <td class="text-center">DBMS LAB (B2)</td>
                        <td class="text-center">EIA</td>
                        <td class="text-center">ES</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">12:15 - 1:00</td>
                        <td class="text-center" colspan="5" class="table-warning"><em>Lunch Break</em></td>
                    </tr>
                    <tr>
                        <td class="fw-bold">1:00 - 2:00</td>
                        <td class="text-center">DBMS</td>
                        <td class="text-center">DBMS LAB (B2)</td>
                        <td class="text-center">LIBRARY</td>
                        <td class="text-center">LIBRARY (B2)</td>
                        <td class="text-center">SPORTS</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">2:00 - 3:00</td>
                        <td class="text-center">LIBRARY</td>
                        <td class="text-center">PQT</td>
                        <td class="text-center">ES</td>
                        <td class="text-center">PE-I</td>
                        <td class="text-center">MENT0RING</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">3:00 - 4:05</td>
                        <td class="text-center">DBMS LAB (B1) / EAD LAB (B2)</td>
                        <td class="text-center">LIBRARY (B1)</td>
                        <td class="text-center"> EAD LAB (B2)</td>
                        <td class="text-center">ES</td>
                        <td class="text-center">PQT (1)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
